APP_ENV=prod
SPRING_PROFILES_ACTIVE=prod
PORT=4108

DB_URL=jdbc:postgresql://192.168.1.123:5432/trading_futuros?currentSchema=futuros_operaciones
DB_USER=postgres
DB_PASSWORD=5450940
DB_SCHEMA=futuros_operaciones

SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=20260530

KAFKA_BROKERS=192.168.1.123:9094
KAFKA_CONSUMER_GROUP=signals-orc-prod
KAFKA_LISTENER_AUTO_STARTUP=true
KAFKA_MAX_POLL_RECORDS=500
KAFKA_FETCH_MIN_BYTES=1
KAFKA_FETCH_MAX_WAIT_MS=50

ENGINE_COPY_LOCK_PROVIDER=postgres

HYPERLIQUID_DIRECT_INGEST_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_REJECT_WHEN_DISABLED=true
HYPERLIQUID_DIRECT_INGEST_DEDUPE_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_DEDUPE_TTL_SECONDS=30
HYPERLIQUID_DIRECT_INGEST_DISTRIBUTED_DEDUPE_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_DEDUPE_LEASE_TTL_MS=60000
HYPERLIQUID_DIRECT_INGEST_FAIL_OPEN_ON_DEDUPE_ERROR=false
HYPERLIQUID_DIRECT_INGEST_LOG_INTERVAL_MS=10000
HYPERLIQUID_DIRECT_INGEST_FALLBACK_DB_ON_DIRECT_FAILURE=true

HYPERLIQUID_ORIGIN_STORE_ENABLED=true
HYPERLIQUID_ORIGIN_STORE_WORKER_THREADS=8
HYPERLIQUID_ORIGIN_STORE_QUEUE_CAPACITY=100000
HYPERLIQUID_ORIGIN_STORE_HYDRATE_OPEN_POSITIONS=true
HYPERLIQUID_ORIGIN_STORE_FAIL_COPY_ON_BIND_ERROR=false
HYPERLIQUID_ORIGIN_STORE_SKIP_LATE_ADJUSTMENTS=true
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_ENABLED=true
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_BASE_URL=https://fapi.binance.com
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_TIMEOUT_MS=300
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_CACHE_TTL_MS=5000
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_CACHE_SIZE=8192
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_MISS_CACHE_TTL_MS=60000
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_MISS_CACHE_SIZE=4096

METRIC_OUTBOX_ENABLED=true
METRIC_OUTBOX_PUBLISHER_ENABLED=true
KAFKA_TOPIC_OPERATION_MOVEMENT_PERSISTED=operation-movement-persisted-v1
METRIC_OUTBOX_PUBLISHER_BATCH_SIZE=1000
METRIC_OUTBOX_PUBLISHER_POLL_MS=500

METRIC_COPY_EVENT_OUTBOX_ENABLED=true
KAFKA_TOPIC_COPY_OPERATION_EVENT_PERSISTED=copy-operation-event-persisted-v1

METRIC_WALLET_DISTRIBUTION_WORKER_ENABLED=true
METRIC_WALLET_SYNC_DISTRIBUTION_ENABLED=true

METRIC_WALLET_HISTORY_SOURCE=joyas
METRIC_WALLET_HISTORY_LIMIT=300
METRIC_WALLET_HISTORY_DAYZ=20
METRIC_WALLET_HISTORY_MIN_HISTORY_DAYS=1
METRIC_WALLET_JOYAS_LIMIT=20
METRIC_WALLET_JOYAS_DAYZ=20
METRIC_WALLET_JOYAS_SIMULATION=summary
METRIC_WALLET_HISTORY_CACHE_REFRESH_AFTER=2m
METRIC_WALLET_HISTORY_CACHE_EXPIRE_AFTER=5m

METRIC_WALLET_COPY_GUARD_ENABLED=true
METRIC_WALLET_COPY_GUARD_WINDOWS=2w,1mo
METRIC_WALLET_COPY_GUARD_MIN_WINDOW_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_MIN_TOTAL_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_REQUIRE_WINDOW_DATA=true
METRIC_WALLET_COPY_GUARD_FAIL_OPEN_ON_MISSING_METRIC=false
METRIC_WALLET_COPY_GUARD_COOLDOWN_HOURS=48

COPY_TRADING_DEFAULT_EXECUTION_MODE=SHADOW

DB_POOL_MAX_SIZE=40
DB_POOL_MIN_IDLE=8
DB_CONNECTION_TIMEOUT_MS=5000
DB_VALIDATION_TIMEOUT_MS=2000
DB_CONNECTION_MAX_LIFETIME_MS=1500000

COPY_JOB_WORKER_POOL_SIZE=24
COPY_JOB_WORKER_QUEUE=50000
COPY_JOB_WORKER_MAX_BATCH=500
COPY_JOB_WORKER_POLL_MS=50

HYPERLIQUID_DIRECT_INGEST_QUEUE_CAPACITY=100000
HYPERLIQUID_DIRECT_INGEST_WORKER_THREADS=8

OPERATION_MOVEMENT_LEDGER_ENABLED=true
OPERATION_MOVEMENT_LEDGER_QUEUE_CAPACITY=100000
OPERATION_MOVEMENT_LEDGER_WORKER_THREADS=8

SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_SWAGGER_UI_ENABLED=false
MANAGEMENT_HEALTH_DB_ENABLED=true

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
JAVA_OPTS='-XX:InitialRAMPercentage=40 -XX:MaxRAMPercentage=70 -XX:+UseG1GC -Dfile.encoding=UTF-8'

# Safe catalog behavior: without BINANCE_SYMBOLS_API_KEY the app now degrades to empty/stale catalog.
BINANCE_SYMBOLS_WARMUP_ON_START=false
BINANCE_SYMBOLS_CACHE_TTL_MS=300000
