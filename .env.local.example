SPRING_PROFILES_ACTIVE=local
APP_ENV=local
PORT=4108
DB_URL=jdbc:postgresql://localhost:5432/trading_futuros?currentSchema=futuros_operaciones
DB_USER=postgres
DB_PASSWORD=postgres
SPRING_FLYWAY_ENABLED=false
KAFKA_LISTENER_AUTO_STARTUP=false
ENGINE_COPY_LOCK_PROVIDER=local
HYPERLIQUID_DIRECT_INGEST_DISTRIBUTED_DEDUPE_ENABLED=false
METRIC_OUTBOX_ENABLED=false
METRIC_OUTBOX_PUBLISHER_ENABLED=false
KAFKA_TOPIC_OPERATION_MOVEMENT_PERSISTED=operation-movement-persisted-v1

# Metric allocator ownership: keep signals runtime only.
METRIC_WALLET_DISTRIBUTION_WORKER_ENABLED=false
METRIC_WALLET_SYNC_DISTRIBUTION_ENABLED=false
METRIC_COPY_EVENT_OUTBOX_ENABLED=false
KAFKA_TOPIC_COPY_OPERATION_EVENT_PERSISTED=copy-operation-event-persisted-v1

# Local runtime knobs.
JAVA_OPTS=-XX:InitialRAMPercentage=30 -XX:MaxRAMPercentage=65 -XX:+UseG1GC -Dfile.encoding=UTF-8
DB_POOL_MAX_SIZE=8
DB_POOL_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=5000
DB_VALIDATION_TIMEOUT_MS=2000
DB_CONNECTION_MAX_LIFETIME_MS=1500000

COPY_JOB_WORKER_POOL_SIZE=4
COPY_JOB_WORKER_QUEUE=5000
HYPERLIQUID_DIRECT_INGEST_QUEUE_CAPACITY=10000
HYPERLIQUID_DIRECT_INGEST_WORKER_THREADS=2
HYPERLIQUID_ORIGIN_STORE_QUEUE_CAPACITY=10000
HYPERLIQUID_ORIGIN_STORE_WORKER_THREADS=2
OPERATION_MOVEMENT_LEDGER_QUEUE_CAPACITY=10000
OPERATION_MOVEMENT_LEDGER_WORKER_THREADS=2

METRIC_WALLET_HISTORY_SOURCE=joyas
METRIC_WALLET_HISTORY_LIMIT=50
METRIC_WALLET_HISTORY_DAYZ=1
METRIC_WALLET_HISTORY_MIN_HISTORY_DAYS=1
METRIC_WALLET_JOYAS_LIMIT=3
METRIC_WALLET_JOYAS_DAYZ=1
METRIC_WALLET_JOYAS_SIMULATION=summary
METRIC_WALLET_COPY_GUARD_ENABLED=true
METRIC_WALLET_COPY_GUARD_WINDOWS=2w,1mo
METRIC_WALLET_COPY_GUARD_MIN_WINDOW_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_MIN_TOTAL_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_REQUIRE_WINDOW_DATA=true
METRIC_WALLET_COPY_GUARD_FAIL_OPEN_ON_MISSING_METRIC=false
METRIC_WALLET_COPY_GUARD_COOLDOWN_HOURS=48

# Set execution_mode=SHADOW per user_copy_allocation for real-price dummy execution.
COPY_TRADING_DEFAULT_EXECUTION_MODE=LIVE

# Movement source semantics:
# hyperliquid_direct_ingest = original wallet data, eligible for joyas/metric ETL.
# copy_job_ingest = derived user-copy data, audit only and excluded from joyas by ETL.
OPERATION_MOVEMENT_LEDGER_ENABLED=true
