SPRING_PROFILES_ACTIVE=prod
APP_ENV=prod
PORT=4108
DB_URL=jdbc:postgresql://<host>:5432/trading_futuros?currentSchema=futuros_operaciones
DB_USER=<user>
DB_PASSWORD=<password>
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=20260530
KAFKA_LISTENER_AUTO_STARTUP=true
ENGINE_COPY_LOCK_PROVIDER=postgres
HYPERLIQUID_DIRECT_INGEST_DISTRIBUTED_DEDUPE_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_FAIL_OPEN_ON_DEDUPE_ERROR=false
METRIC_OUTBOX_ENABLED=true
METRIC_OUTBOX_PUBLISHER_ENABLED=true
KAFKA_TOPIC_OPERATION_MOVEMENT_PERSISTED=operation-movement-persisted-v1
METRIC_OUTBOX_PUBLISHER_BATCH_SIZE=200
METRIC_OUTBOX_PUBLISHER_POLL_MS=1000

# Metric allocator ownership: ETL owns distribution, signals only reads user_copy_allocation.
METRIC_WALLET_DISTRIBUTION_WORKER_ENABLED=false
METRIC_WALLET_SYNC_DISTRIBUTION_ENABLED=false
METRIC_COPY_EVENT_OUTBOX_ENABLED=true
KAFKA_TOPIC_COPY_OPERATION_EVENT_PERSISTED=copy-operation-event-persisted-v1

# JVM / DB pool for high-volume copy trading persistence.
JAVA_OPTS=-XX:InitialRAMPercentage=40 -XX:MaxRAMPercentage=70 -XX:+UseG1GC -Dfile.encoding=UTF-8
DB_POOL_MAX_SIZE=24
DB_POOL_MIN_IDLE=4
DB_CONNECTION_TIMEOUT_MS=5000
DB_VALIDATION_TIMEOUT_MS=2000
DB_CONNECTION_MAX_LIFETIME_MS=1500000

# High-throughput queues. Tune down if DB/CPU is smaller.
COPY_JOB_WORKER_POOL_SIZE=12
COPY_JOB_WORKER_QUEUE=20000
COPY_JOB_WORKER_MAX_BATCH=500
COPY_JOB_WORKER_POLL_MS=50
HYPERLIQUID_DIRECT_INGEST_QUEUE_CAPACITY=50000
HYPERLIQUID_DIRECT_INGEST_WORKER_THREADS=6
HYPERLIQUID_ORIGIN_STORE_QUEUE_CAPACITY=50000
HYPERLIQUID_ORIGIN_STORE_WORKER_THREADS=4
OPERATION_MOVEMENT_LEDGER_QUEUE_CAPACITY=50000
OPERATION_MOVEMENT_LEDGER_WORKER_THREADS=4

# Metric wallet source: use joyas strategy compilation from ms-metrica-cuenta.
METRIC_WALLET_HISTORY_SOURCE=joyas
METRIC_WALLET_HISTORY_LIMIT=300
METRIC_WALLET_HISTORY_DAYZ=1
METRIC_WALLET_HISTORY_MIN_HISTORY_DAYS=1
METRIC_WALLET_JOYAS_LIMIT=3
METRIC_WALLET_JOYAS_DAYZ=1
METRIC_WALLET_JOYAS_SIMULATION=summary
METRIC_WALLET_COPY_GUARD_ENABLED=true
METRIC_WALLET_COPY_GUARD_WINDOWS=2w,1mo
METRIC_WALLET_COPY_GUARD_MIN_WINDOW_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_MIN_TOTAL_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_REQUIRE_WINDOW_DATA=true
METRIC_WALLET_COPY_GUARD_FAIL_OPEN_ON_MISSING_METRIC=false
METRIC_WALLET_COPY_GUARD_COOLDOWN_HOURS=48
METRIC_WALLET_HISTORY_CACHE_REFRESH_AFTER=2m
METRIC_WALLET_HISTORY_CACHE_EXPIRE_AFTER=5m

# Set execution_mode=SHADOW per user_copy_allocation for real-price dummy execution.
COPY_TRADING_DEFAULT_EXECUTION_MODE=LIVE
