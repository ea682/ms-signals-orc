# Copy to .env.prod locally. Never commit real values.
SPRING_PROFILES_ACTIVE=prod
APP_ENV=prod
PORT=4108
DB_URL=jdbc:postgresql://postgres:5432/copy_trading?currentSchema=futuros_operaciones
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_SCHEMA=futuros_operaciones
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true
SPRING_FLYWAY_BASELINE_VERSION=20260530
DB_POOL_MAX_SIZE=40
DB_POOL_MIN_IDLE=8
DB_CONNECTION_TIMEOUT_MS=5000
DB_VALIDATION_TIMEOUT_MS=2000
DB_CONNECTION_MAX_LIFETIME_MS=1500000
KAFKA_BROKERS=kafka:9092
KAFKA_LISTENER_AUTO_STARTUP=true
URL_METRIC=http://ms-metrica-cuenta:4102/
URL_BINANCE=http://ms-binance-engine:4106

# Durable movement and copy-event publication.
METRIC_OUTBOX_ENABLED=true
METRIC_OUTBOX_PUBLISHER_ENABLED=true
KAFKA_TOPIC_OPERATION_MOVEMENT_PERSISTED=operation-movement-persisted-v1
KAFKA_TOPIC_COPY_OPERATION_EVENT_PERSISTED=copy-operation-event-persisted-v1
METRIC_COPY_EVENT_OUTBOX_ENABLED=true
METRIC_OUTBOX_PUBLISHER_BATCH_SIZE=200
METRIC_OUTBOX_PUBLISHER_POLL_MS=1000
METRIC_WALLET_DISTRIBUTION_WORKER_ENABLED=false
METRIC_WALLET_SYNC_DISTRIBUTION_ENABLED=false

# Multi-replica source ingestion and copy hot-path safety.
ENGINE_COPY_LOCK_PROVIDER=postgres
HYPERLIQUID_DIRECT_INGEST_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_DEDUPE_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_DISTRIBUTED_DEDUPE_ENABLED=true
HYPERLIQUID_DIRECT_INGEST_FAIL_OPEN_ON_DEDUPE_ERROR=false
HYPERLIQUID_DIRECT_INGEST_QUEUE_CAPACITY=100000
HYPERLIQUID_DIRECT_INGEST_WORKER_THREADS=8
HYPERLIQUID_ORIGIN_STORE_QUEUE_CAPACITY=100000
HYPERLIQUID_ORIGIN_STORE_WORKER_THREADS=8
OPERATION_MOVEMENT_LEDGER_ENABLED=true
OPERATION_MOVEMENT_LEDGER_QUEUE_CAPACITY=100000
OPERATION_MOVEMENT_LEDGER_WORKER_THREADS=8
JAVA_OPTS=-XX:InitialRAMPercentage=40 -XX:MaxRAMPercentage=70 -XX:+UseG1GC -Dfile.encoding=UTF-8
COPY_JOB_WORKER_POOL_SIZE=24
COPY_JOB_WORKER_QUEUE=50000
COPY_JOB_WORKER_MAX_BATCH=500
COPY_JOB_WORKER_POLL_MS=50
COPY_RUNTIME_FORBID_DB_IN_LIVE_HOT_PATH=true
COPY_RUNTIME_USER_SNAPSHOT_REFRESH_MS=60000
COPY_RUNTIME_USER_SNAPSHOT_MAX_STALE=PT10M
COPY_RUNTIME_ALLOCATION_SNAPSHOT_REFRESH_MS=5000
COPY_RUNTIME_ALLOCATION_SNAPSHOT_MAX_STALE=PT30S
METRIC_WALLET_READ_MODE=V2
METRIC_WALLET_HISTORY_SOURCE=joyas
METRIC_WALLET_HISTORY_LIMIT=300
METRIC_WALLET_HISTORY_DAYZ=1
METRIC_WALLET_HISTORY_MIN_HISTORY_DAYS=1
METRIC_WALLET_JOYAS_LIMIT=3
METRIC_WALLET_JOYAS_DAYZ=1
METRIC_WALLET_JOYAS_SIMULATION=summary
METRIC_WALLET_V2_SUMMARY_REFRESH_AFTER=PT2M
METRIC_WALLET_V2_FULL_REFRESH_AFTER=PT10M
METRIC_WALLET_V2_COPY_GUARD_REFRESH_AFTER=PT2M
METRIC_WALLET_V2_MAX_STALENESS=PT10M
METRIC_WALLET_V2_FAIL_OPEN_NEW_EXPOSURE=false
METRIC_WALLET_V2_ALLOW_CLOSE_ON_FAILURE=true
METRIC_WALLET_V2_SHADOW_AUTO_ENROLL_ENABLED=false
METRIC_WALLET_COPY_GUARD_ENABLED=true
METRIC_WALLET_COPY_GUARD_WINDOWS=2w,1mo
METRIC_WALLET_COPY_GUARD_MIN_WINDOW_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_MIN_TOTAL_PNL_USDT=0
METRIC_WALLET_COPY_GUARD_REQUIRE_WINDOW_DATA=true
METRIC_WALLET_COPY_GUARD_FAIL_OPEN_ON_MISSING_METRIC=false
METRIC_WALLET_COPY_GUARD_COOLDOWN_HOURS=48
METRIC_WALLET_HISTORY_CACHE_REFRESH_AFTER=2m
METRIC_WALLET_HISTORY_CACHE_EXPIRE_AFTER=5m

# Production Micro-live invariant: exactly 100 USDC and x5.
COPY_MICRO_LIVE_ENABLED=true
COPY_MICRO_LIVE_MAX_CAPITAL_AMOUNT=100
COPY_MICRO_LIVE_INITIAL_CAPITAL_USD=100
COPY_MICRO_LIVE_MAX_CAPITAL_USD=100
COPY_MICRO_LIVE_TOTAL_CAPITAL_USD=100
COPY_MICRO_LIVE_TARGET_LEVERAGE=5
COPY_MICRO_LIVE_RESERVED_CAPITAL_USD=100
MICRO_LIVE_BUDGET_PER_ALLOCATION_USDC=100
MICRO_LIVE_CAPACITY_SAFETY_BUFFER_USDC=0
MICRO_LIVE_MAX_CONCURRENT_ALLOCATIONS=0
MICRO_LIVE_RESERVED_RECERTIFICATION_SLOTS=0
MICRO_LIVE_RECERTIFICATION_PREEMPTION_POLICY=IDLE_ONLY
MICRO_LIVE_CAPACITY_SNAPSHOT_TTL_SECONDS=300
MICRO_LIVE_RECERTIFICATION_JOB_ENABLED=true
MICRO_LIVE_RECERTIFICATION_INITIAL_DELAY_MS=30000
MICRO_LIVE_RECERTIFICATION_FIXED_DELAY_MS=15000
MICRO_LIVE_RECERTIFICATION_BATCH_SIZE=20
COPY_PROMOTION_ENABLED=true
COPY_PROMOTION_FROM_SHADOW_ENABLED=true
COPY_PROMOTION_DEFAULT_TARGET_MODE=MICRO_LIVE
COPY_PROMOTION_DIRECT_LIVE_POLICY=REQUIRE_MICRO_LIVE
COPY_PROMOTION_JOB_ENABLED=true
COPY_PROMOTION_MIN_SHADOW_DAYS=3
COPY_PROMOTION_MIN_SHADOW_EVENTS=10
COPY_PROMOTION_MIN_SHADOW_CLOSED_POSITIONS=3
COPY_PROMOTION_MIN_SHADOW_COVERAGE_PCT=95
COPY_PROMOTION_REQUIRE_COPY_GUARD_OPEN=true
COPY_PROMOTION_REQUIRE_FULL_DECISION_FOR_MICRO_LIVE=true
SHADOW_PROMOTION_COVERAGE_ROLLING_ENABLED=true
SHADOW_COVERAGE_MODE=ROLLING
SHADOW_PROMOTION_COVERAGE_WINDOW_DAYS=14
SHADOW_PROMOTION_COVERAGE_MIN_EVENTS=100
SHADOW_PROMOTION_COVERAGE_MIN_PERCENT=95

# Automatic global certification after valid real Micro-live evidence.
COPY_LIVE_PROMOTION_ENABLED=true
COPY_LIVE_PROMOTION_MANUAL_CERTIFICATION_REQUIRED=false
COPY_LIVE_PROMOTION_JOB_ENABLED=true
COPY_LIVE_PROMOTION_MIN_SUBMITTED_ORDERS=10
COPY_LIVE_PROMOTION_MIN_ACKNOWLEDGED_ORDERS=10
COPY_LIVE_PROMOTION_MIN_FILLED_ORDERS=10
COPY_LIVE_PROMOTION_MIN_CLOSED_OPERATIONS=3
COPY_LIVE_PROMOTION_MAX_DISPATCH_ERRORS=0
COPY_LIVE_PROMOTION_MAX_RECONCILIATION_PENDING=0
COPY_LIVE_PROMOTION_MAX_DUPLICATE_COUNT=0
COPY_LIVE_PROMOTION_MAX_UNRESOLVED_AMBIGUOUS_TIMEOUTS=0
COPY_LIVE_PROMOTION_REQUIRE_FULL_DECISION_FOR_LIVE=true
COPY_CERTIFICATION_EXCHANGE=BINANCE
COPY_CERTIFICATION_STRATEGY_VERSION=copy-strategy-v3
COPY_CERTIFICATION_SIZING_POLICY_VERSION=proportional-portfolio-v3
COPY_CERTIFICATION_SYMBOL_MAPPING_VERSION=binance-symbol-map-v3
COPY_CERTIFICATION_FEE_MODEL_VERSION=binance-fee-v3
COPY_CERTIFICATION_FUNDING_MODEL_VERSION=binance-funding-v3
COPY_CERTIFICATION_SLIPPAGE_MODEL_VERSION=binance-round-trip-execution-v1
COPY_CERTIFICATION_LIQUIDITY_MODEL_VERSION=order-book-liquidity-v3

# Audit-only defaults. Enable the two masters only after setting a non-empty canary whitelist.
COPY_NEW_DISPATCH_ENABLED=false
BINANCE_ORDER_SUBMIT_ENABLED=false
COPY_LIVE_ENABLED=true
COPY_LIVE_CANARY_ENABLED=true
COPY_LIVE_DRY_RUN=true
COPY_LIVE_SIZING_MODE=SOURCE_EXPOSURE_PERCENT
COPY_LIVE_REQUIRE_SOURCE_EXPOSURE=true
COPY_LIVE_WHITELIST_USER_IDS=
COPY_LIVE_WHITELIST_WALLET_IDS=
COPY_LIVE_WHITELIST_SYMBOLS=
COPY_LIVE_WHITELIST_ALLOCATION_IDS=
COPY_LIVE_WHITELIST_STRATEGY_CODES=
COPY_RECONCILIATION_ENABLED=true
COPY_LIVE_ADOPTION_RECONCILIATION_ENABLED=true
COPY_LIVE_ADOPTION_VALIDITY=24h
COPY_RECONCILIATION_FIXED_DELAY_MS=5000
BINANCE_TRADING_CONFIG_PRECONFIGURE_ENABLED=true
BINANCE_TRADING_CONFIG_PRECONFIGURE_MARGIN_TYPE=CROSSED
BINANCE_TRADING_CONFIG_PRECONFIGURE_POSITION_MODE=ONE_WAY
BINANCE_SYMBOLS_WARMUP_ON_START=false
BINANCE_SYMBOLS_CACHE_TTL_MS=300000
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_ENABLED=true
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_TIMEOUT_MS=300
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_CACHE_TTL_MS=5000
HYPERLIQUID_ORIGIN_STORE_BINANCE_PRICE_CACHE_SIZE=8192

# Read-only calibration remains analytic and is not a promotion gate.
COPY_CALIBRATION_MEDIUM_SAMPLE_SIZE=10
COPY_CALIBRATION_HIGH_SAMPLE_SIZE=30
COPY_CALIBRATION_MAXIMUM_AGE=P14D

# The B2B override must never be enabled in production.
COPY_B2B_REAL_MONEY_ENABLED=false
COPY_B2B_REAL_MONEY_EMERGENCY_STOP=true
COPY_B2B_MICRO_LIVE_EXECUTION_ACCOUNT_ID=
COPY_B2B_LIVE_EXECUTION_ACCOUNT_ID=
