# Copy to .env.b2b locally and use only with SPRING_PROFILES_ACTIVE=b2b.
# Keep EMERGENCY_STOP=true until the account has been inspected immediately before the run.
SPRING_PROFILES_ACTIVE=prod,b2b
APP_ENV=b2b
DB_URL=jdbc:postgresql://localhost:5432/copy_trading_b2b
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_SCHEMA=futuros_operaciones
URL_METRIC=http://localhost:4102/
URL_BINANCE=http://localhost:4106

COPY_B2B_REAL_MONEY_ENABLED=true
COPY_B2B_REAL_MONEY_EXPLICIT_ACKNOWLEDGEMENT=I_ACCEPT_MAX_10_USDC_REAL_MARGIN
COPY_B2B_REAL_MONEY_EMERGENCY_STOP=true
COPY_B2B_REAL_MONEY_MANUAL_POSITIONS_VERIFIED=false
COPY_B2B_REAL_MONEY_TEST_USER_ID=replace_with_dedicated_test_user_uuid
COPY_B2B_MICRO_LIVE_EXECUTION_ACCOUNT_ID=replace_with_micro_live_execution_account_uuid
COPY_B2B_LIVE_EXECUTION_ACCOUNT_ID=replace_with_live_execution_account_uuid
COPY_B2B_REAL_MONEY_ALLOWED_SYMBOLS=BTCUSDC,ETHUSDC
COPY_B2B_REAL_MONEY_CLIENT_ORDER_ID_PREFIX=codex-b2b-
COPY_B2B_REAL_MONEY_MAX_TOTAL_MARGIN_USD=10
COPY_B2B_REAL_MONEY_MAX_NOTIONAL_USD=50
COPY_B2B_REAL_MONEY_MAX_LEVERAGE=5
COPY_B2B_REAL_MONEY_MAX_ORDERS=14

# The production model remains 100 USDC/x5; this profile only caps actual B2B orders.
COPY_MICRO_LIVE_ENABLED=true
COPY_MICRO_LIVE_MAX_CAPITAL_AMOUNT=100
COPY_MICRO_LIVE_INITIAL_CAPITAL_USD=100
COPY_MICRO_LIVE_MAX_CAPITAL_USD=100
COPY_MICRO_LIVE_TOTAL_CAPITAL_USD=100
COPY_MICRO_LIVE_TARGET_LEVERAGE=5
MICRO_LIVE_BUDGET_PER_ALLOCATION_USDC=100
MICRO_LIVE_CAPACITY_SAFETY_BUFFER_USDC=0
MICRO_LIVE_MAX_CONCURRENT_ALLOCATIONS=0
MICRO_LIVE_RESERVED_RECERTIFICATION_SLOTS=0
MICRO_LIVE_RECERTIFICATION_PREEMPTION_POLICY=IDLE_ONLY
COPY_MICRO_LIVE_RESERVED_CAPITAL_USD=100
BINANCE_TRADING_CONFIG_PRECONFIGURE_MARGIN_TYPE=CROSSED
BINANCE_TRADING_CONFIG_PRECONFIGURE_POSITION_MODE=ONE_WAY
COPY_NEW_DISPATCH_ENABLED=true
BINANCE_ORDER_SUBMIT_ENABLED=true
# The direct dual-account harness uses a temporary in-memory x5 override and restores
# the original Binance leverage after each account. These switches remain fail-closed.
COPY_LIVE_ENABLED=false
COPY_LIVE_CANARY_ENABLED=false
COPY_LIVE_DRY_RUN=true
COPY_LIVE_ADOPTION_RECONCILIATION_ENABLED=false
ENGINE_COPY_LOCK_PROVIDER=postgres
HYPERLIQUID_DIRECT_INGEST_DISTRIBUTED_DEDUPE_ENABLED=true
